# ═══════════════════════════════════════════════════════════════
# Polymarket Direct SDK — Environment Variables
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Polymarket Builder API (REQUIRED) ─────────────────────────
# Your Ethereum wallet private key on Polygon (hex, with or without 0x)
POLY_PRIVATE_KEY=0x...

# L2 CLOB API credentials — derived once from your wallet.
# Run: python polymarket_sdk/poly_auth.py derive
# Then paste the output values here.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Optional: separate funder wallet address (if using proxy pattern)
# POLY_FUNDER=0x...

# Optional: Polygon chain ID (default: 137)
# POLY_CHAIN_ID=137

# Optional: Polygon RPC URL for on-chain redemptions
# POLY_RPC_URL=https://polygon-rpc.com

# ── Trading config (unchanged from Simmer setup) ──────────────
PKNWITQ_MODE=both
PKNWITQ_INTERVAL=20
PKNWITQ_ASSET=BTC
PKNWITQ_WINDOW=5m

SIMMER_SPRINT_ENTRY=0.05
SIMMER_SPRINT_MOMENTUM=0.15
SIMMER_SPRINT_MAX_POSITION=5.0
SIMMER_SPRINT_DAILY_BUDGET=10.0
SIMMER_SPRINT_COMP_THRESH=0.60
SIMMER_SPRINT_ASSET=BTC
SIMMER_SPRINT_WINDOW=5m

# Optional: Telegram/Discord webhook for trade alerts
# SIMMER_WEBHOOK_URL=https://...
